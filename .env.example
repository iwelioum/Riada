# JWT Configuration
# Generate with: dotnet user-secrets set "Jwt:SecretKey" "<your-256-bit-base64-secret>"
# OR set environment variable: JWT_SECRET_KEY=<your-256-bit-base64-secret>
JWT_SECRET_KEY=your_256_bit_base64_encoded_secret_here

# Authentication
ALLOW_DEV_BYPASS=false

# Database
ConnectionStrings__RiadaDb=Server=localhost;Port=3306;Database=riada_db;User=root;Password=YOUR_PASSWORD;SslMode=Preferred;AllowPublicKeyRetrieval=True

# Environment
ASPNETCORE_ENVIRONMENT=Development
