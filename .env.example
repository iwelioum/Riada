# JWT Configuration
# Generate with: dotnet user-secrets set "Jwt:SecretKey" "<your-256-bit-base64-secret>"
# OR set environment variable: JWT_SECRET_KEY=<your-256-bit-base64-secret>
JWT_SECRET_KEY=your_256_bit_base64_encoded_secret_here

# Authentication
ALLOW_DEV_BYPASS=false

# Database
RIADA_DB_CONNECTION_STRING=Server=localhost;Port=3306;Database=riada_db;User=root;Password=YOUR_PASSWORD;SslMode=Preferred;AllowPublicKeyRetrieval=True

# Environment
ASPNETCORE_ENVIRONMENT=Development

# Rate Limiting
RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_LOGIN_WINDOW_MINUTES=1
RATE_LIMIT_REGISTER_ATTEMPTS=3
RATE_LIMIT_REGISTER_WINDOW_HOURS=1
