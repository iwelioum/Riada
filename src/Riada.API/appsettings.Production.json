{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Jwt": {
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7,
    "Cookies": {
      "AccessTokenName": "riada_access_token",
      "RefreshTokenName": "riada_refresh_token"
    }
  },
  "AllowedOrigins": {
    "Production": "https://riada.example.com"
  }
}
