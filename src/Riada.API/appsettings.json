{
  "ConnectionStrings": {
    "RiadaDb": "${RIADA_DB_CONNECTION_STRING:Server=localhost;Port=3306;Database=riada_db;User=root;Password=YOUR_PASSWORD;SslMode=Preferred;AllowPublicKeyRetrieval=True}"
  },
  "Jwt": {
    "Issuer": "Riada.API",
    "Audience": "Riada.Clients",
    "SecretKey": "${JWT_SECRET_KEY}",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "AllowedOrigins": {
    "Production": "https://riada.example.com",
    "Staging": "https://staging.riada.example.com"
  },
  "RateLimit": {
    "Login": {
      "Attempts": 5,
      "WindowMinutes": 1
    },
    "Register": {
      "Attempts": 3,
      "WindowHours": 1
    },
    "ApiDefault": {
      "Requests": 100,
      "WindowMinutes": 1
    }
  },
  "IpRateLimit": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "HttpStatusCode": 429,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "Endpoint": "*:/api/*",
    "GeneralRules": [
      {
        "Endpoint": "*:/api/auth/token",
        "Period": "1m",
        "Limit": 5
      },
      {
        "Endpoint": "*:/api/auth/refresh",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 100
      }
    ]
  },
  "IpRateLimitPolicies": {
    "IpWhitelist": [
      "127.0.0.1",
      "::1/128"
    ],
    "EndpointWhitelist": [
      "*:/health"
    ],
    "ClientWhitelist": []
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  }
}

